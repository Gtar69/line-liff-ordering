# 複製為 .env.local 後填入實際值；.env* 不可 commit（見 .gitignore）

# --- 資料庫（Issue #3 起使用）---
# PostgreSQL 連線字串，例如 Neon / Supabase
DATABASE_URL=

# --- 後台 / 廚房（Issue #6 起使用）---
# Admin / 廚房共用單一 token，僅後端使用，不可進前端 bundle
ADMIN_API_TOKEN=

# --- LINE LIFF（Issue #11 起使用，資源尚未建立）---
# 公開值，前端可見
LIFF_ID=
# 後端驗證 idToken 的 aud
LINE_LOGIN_CHANNEL_ID=
# secret，僅後端使用
LINE_LOGIN_CHANNEL_SECRET=
